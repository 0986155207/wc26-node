# ============================================================
#  WORLD CUP 2026 LIVE — Biến môi trường
#  Sao chép file này thành .env (local) và khai báo trên Vercel:
#  Project → Settings → Environment Variables
# ============================================================

# Neon PostgreSQL — lấy connection string tại https://console.neon.tech
# (Dashboard → Connection Details → chọn "Pooled connection")
DATABASE_URL="...."

# Gemini API — lấy miễn phí tại https://aistudio.google.com/apikey
GEMINI_API_KEY="...."
# football-data.org — đăng ký miễn phí tại https://www.football-data.org/client/register
# (gói Free có đầy đủ FIFA World Cup). Có thể bỏ trống: hệ thống sẽ
# dùng Gemini + Google Search làm nguồn dự phòng.
FOOTBALL_DATA_TOKEN="..."

# Khóa bảo vệ endpoint cron /api/daily — Vercel tự gửi kèm
# header "Authorization: Bearer <CRON_SECRET>". Tự đặt chuỗi ngẫu nhiên dài.
CRON_SECRET="doi-chuoi-ngau-nhien-dai-cua-rieng-ban"

# ---- THÔNG BÁO ĐẨY (Web Push) ----
# Tạo cặp khóa bằng lệnh:  npx web-push generate-vapid-keys
# Dán publicKey và privateKey vào 2 biến dưới đây.
VAPID_PUBLIC_KEY="...."
VAPID_PRIVATE_KEY="...."
VAPID_SUBJECT="mailto:email@gmail.com"
